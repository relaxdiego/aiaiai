# Mode for this machine: "full" (runs LiteLLM locally) or "client" (connects to a remote gateway)
export MACHINE_MODE=full

# LiteLLM gateway base URL — full mode: http://127.0.0.1:4000 / client mode: http://<host>:4000
export GATEWAY_BASE_URL=http://127.0.0.1:4000

# Key used to authenticate clients (Claude Code, pi.dev) to the LiteLLM gateway
# Full mode: auto-generated by 'make setup'. Client mode: copy from 'make show-key' on the gateway machine.
export LITELLM_MASTER_KEY=sk-CHANGEME

# PostgreSQL database for LiteLLM UI and user management (full mode only)
export DATABASE_URL=postgresql://postgres@127.0.0.1/litellm

# LiteLLM spend cap in USD per budget_duration (full mode only). 'make setup'
# renders this into the generated litellm/config.yaml as a literal value. To
# change it, edit here and re-run 'make setup' (no git commit needed).
export LITELLM_MAX_BUDGET=120

# SearXNG secret_key for the local web-search backend (full mode only).
# Auto-generated by 'make setup'. Overrides server.secret_key in searxng/settings.yml.
export SEARXNG_SECRET=CHANGEME

# Base URL the LiteLLM websearch_interception callback uses to reach SearXNG
# (full mode only). REQUIRED: the callback reads this env var directly and does
# NOT use the api_base in litellm/config.yaml's search_tools block. Must match
# searxng/settings.yml's bind_address:port (default localhost loopback).
export SEARXNG_API_BASE=http://127.0.0.1:8888

# --- Full mode only: upstream provider credentials referenced in litellm/config.yaml ---
# Include only the providers you're using; omit the rest.

# Anthropic API (optional)
export ANTHROPIC_API_KEY=sk-ant-CHANGEME

# AWS Bedrock (optional)
export AWS_BEARER_TOKEN_BEDROCK=CHANGEME
export AWS_REGION=us-east-1
