# Machine-local secrets — never commit
.envrc.local

# Devbox and direnv local state
.devbox/
.direnv/

# Python virtual environment (created by setup wizard in full mode)
.venv/

# uv resolver cache
.uv/

# process-compose service logs (rotated, but the dir itself is local-only)
logs/

# Generated by 'make setup' from the committed *.example templates.
# Never edit these by hand — edit the .example and re-run 'make setup'.
litellm/config.yaml
searxng/settings.yml
