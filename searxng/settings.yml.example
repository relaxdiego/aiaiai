use_default_settings: true

general:
  debug: false               # WARNING-level logs only — keeps log volume low

server:
  bind_address: "127.0.0.1"  # never publicly exposed
  port: 8888
  secret_key: ""             # overridden by $SEARXNG_SECRET at runtime
  limiter: false             # no public bot protection needed → no Redis
  image_proxy: false         # image proxying is the main memory sink — keep off

search:
  formats:
    - html
    - json                   # LiteLLM's searxng backend requires the JSON API

# Disable engines that serve CAPTCHAs to unauthenticated self-hosted instances
# (Google/Startpage rate-limit by IP and suspend for 1h, spamming the logs).
# Result quality is unaffected — DuckDuckGo, Wikipedia, etc. still answer.
engines:
  - name: google
    disabled: true
  - name: startpage
    disabled: true
